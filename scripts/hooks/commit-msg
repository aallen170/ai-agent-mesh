#!/bin/sh
# Require commit messages to reference one or more AIMESH tickets.
# Valid formats:
#   AIMESH-9: add device registry service
#   AIMESH-10, AIMESH-14: task router and worker contract

commit_msg=$(cat "$1")
pattern="^AIMESH-[0-9]+(,\s*AIMESH-[0-9]+)*:"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ERROR: Commit message must start with a ticket number, e.g.:"
  echo "  AIMESH-9: add device registry service"
  echo "  AIMESH-10, AIMESH-14: task router and worker contract"
  echo ""
  exit 1
fi
